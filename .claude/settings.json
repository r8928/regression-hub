{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint:fix > /dev/null 2>&1 || true",
            "shell": "bash",
            "timeout": 120,
            "statusMessage": "Running lint:fix..."
          }
        ]
      }
    ]
  }
}
